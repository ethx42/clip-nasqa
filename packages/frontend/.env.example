# AppSync GraphQL (from `npx sst deploy` output)
NEXT_PUBLIC_APPSYNC_URL=
NEXT_PUBLIC_APPSYNC_API_KEY=
NEXT_PUBLIC_AWS_REGION=us-east-1

# AWS credentials for server-side DynamoDB access
# Uses MY_AWS_* prefix because Netlify reserves AWS_* variables
MY_AWS_ACCESS_KEY_ID=
MY_AWS_SECRET_ACCESS_KEY=
MY_AWS_REGION=us-east-1

# DynamoDB table name (from `npx sst deploy` output → tableName)
NASQA_TABLE_NAME=
